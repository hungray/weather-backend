rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. المقالات (Articles)
    // يمكن لأي شخص قراءة المقالات، لكن إنشاء المقالات، وتعديلها، وحذفها يتطلب تسجيل الدخول
    match /articles/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 2. الذكاء الاصطناعي (AI Data)
    // نسمح للجميع بالقراءة والكتابة لضمان عمل "التعلم الذاتي" للذكاء الاصطناعي بدون حساب
    match /weather_reports_detailed/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /system_data/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /city_lessons/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. بيانات المستخدمين (Users)
    // إذا كنت ستحفظ بيانات المستخدمين، لا تسمح لأحد بتعديلها سوى صاحب الحساب نفسه
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 4. الحظر الافتراضي
    // أي مسار آخر غير مذكور في الأعلى سيكون محظوراً تماماً لحماية البيانات المخفية
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
